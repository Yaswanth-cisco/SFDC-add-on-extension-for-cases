{
  "manifest_version": 3,
  "name": "SFDC Case Scraper",
  "version": "1.3.0",
  "description": "Scrapes Salesforce Lightning Case data",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://*.salesforce.com/*",
    "https://*.force.com/*",
    "https://*.lightning.force.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.salesforce.com/*",
        "https://*.force.com/*",
        "https://*.lightning.force.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}